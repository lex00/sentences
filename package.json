{
  "name": "sentences",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Effects-rich, interactive Reed-Kellogg sentence-diagram renderer",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
